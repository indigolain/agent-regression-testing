{
  "name": "agent-regression-testing",
  "version": "0.1.15",
  "description": "A standalone library for AI agent regression testing using LLM-as-judge evaluation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-regression-testing": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "agent",
    "regression",
    "testing",
    "llm",
    "evaluation",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/indigolain/agent-regression-testing.git"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "yaml": "2.8.4"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=7.3.2 <8"
    }
  }
}
