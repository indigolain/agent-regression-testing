{
  "name": "agent-regression-testing",
  "version": "0.1.9",
  "description": "A standalone library for AI agent regression testing using LLM-as-judge evaluation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-regression-testing": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "agent",
    "regression",
    "testing",
    "llm",
    "evaluation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/indigolain/agent-regression-testing.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "yaml": "2.8.3"
  }
}
